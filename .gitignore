/*

## Allowlist
!.gitignore
!.gitmodules
!README.md

# Source code
!/src/
!/include/
!/lib/
!/components/
# Config header template
!/include/user_config.h.tmpl
/include/user_config.h
# Build system
!/platformio.ini
!/CMakeLists.txt
!/sdkconfig.defaults
!/partitions.csv
!/.clang-format*
!/LICENSE
# External dependencies (submodules)
!/external/

# Macintosh apps
!/mac-app/

# Home Assistant automation
!/homeassistant/

# Others
!/assets/
!/data/
!/tools/
!/enclosure/
!/cyd_800k.dsk

## Denylist
# Build artifacts
.pio/
build/
**/*.o
**/*.elf
**/*.map
dependencies.lock
sdkconfig.esp*

# ESP-IDF managed components
managed_components/


# Build data (patched ROM + disk image, generated from vendor/)
data/*
!data/.gitkeep

# Vendor: copyrighted Apple ROM/disk images (user-supplied)
vendor/*
!vendor/.gitkeep
